# ============================================
# Configuration des tests E2E FleetMaster Pro
# ============================================
#
# Copier ce fichier en .env.test et remplir les valeurs
# Ne JAMAIS commiter .env.test avec de vraies credentials!

# ============================================
# URL de l'application
# ============================================
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# ============================================
# Supabase (mêmes valeurs que .env.local)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# ============================================
# Stripe (mode TEST uniquement!)
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# Utilisateurs de test (créés manuellement dans Supabase)
# ============================================
# Ces utilisateurs doivent exister dans Supabase Auth avant de lancer les tests

# Super Admin
TEST_SUPERADMIN_EMAIL=superadmin@example.com
TEST_SUPERADMIN_PASSWORD=your_password

# Company A (utilisé pour tests d'isolation)
TEST_COMPANY_A_EMAIL=company-a@example.com
TEST_COMPANY_A_PASSWORD=your_password

# Company B (entreprise différente pour tests d'isolation)
TEST_COMPANY_B_EMAIL=company-b@example.com
TEST_COMPANY_B_PASSWORD=your_password

# Company A - User standard (permissions limitées)
TEST_COMPANY_A_USER_EMAIL=user@example.com
TEST_COMPANY_A_USER_PASSWORD=your_password

# ============================================
# Configuration CI (GitHub Actions)
# ============================================
# CI=true
# GITHUB_ACTIONS=true

# ============================================
# Options de debug
# ============================================
# DEBUG=pw:api
# PWDEBUG=1
# HEADLESS=false
